\newcommand{\arga}[2]{^{\proof{#1};\refu{#2}}\mathcal{A}}
\newcommand{\argA}[3]{^{\proof{#1},\_;\refu{#2},\_:#3}\mathcal{A}}
\newcommand{\argc}[1]{\mathcal{A}^{#1}}
\newcommand{\argac}[3]{^{\proof{#1};\refu{#2}}\mathcal{A}^{#3}}
\newcommand{\argAc}[4]{^{\proof{#1},\_;\refu{#2},\_:#3}\mathcal{A}^{#4}}

\newcommand{\subarg}[2]{#1 \subset #2}

\newcommand{\axiom}[2]{\infer0{\pro{\Sigma},#1:\pro{#2};\refu{\Delta}\vdash #1:\pro{#2}}}
\newcommand{\proimplintro}[4]{\hypo{\pro{\Sigma},#1:\pro{#2};\refu{\Delta}\vdash #3:\pro{#4}}
      \infer1{\pro{\Sigma};\refu{\Delta}\vdash \lambda #1:#2.#3:\pro{#2 \rightarrow #4}}}

\newcommand{\holeproimplintro}[6]{\hypo{\pro{\Sigma},#1:\pro{#2};\refu{\Delta}\vdash #3:#5\pro{#4}#6}
      \infer1{\pro{\Sigma};\refu{\Delta}\vdash \lambda #1:#2.#3:#5\pro{#2 \rightarrow #4}#6}}

    
\newcommand{\prodiffintro}[4]{\hypo{\pro{\Sigma};\refu{\Delta}\vdash #1:\refu{#2}}
      \hypo{\pro{\Sigma};\refu{\Delta}\vdash #3:\pro{#4}}
      \infer2{\pro{\Sigma};\refu{\Delta}\vdash #1 \circ #3:\pro{#4-#2}}}

\newcommand{\holeprodiffintro}[8]{\hypo{\pro{\Sigma};\refu{\Delta}\vdash #1:#5\refu{#2}#6}
      \hypo{\pro{\Sigma};\refu{\Delta}\vdash #3:#7\pro{#4}#8}
      \infer2{\pro{\Sigma};\refu{\Delta}\vdash #1 \circ #3 : #5 ; #7 \pro{#4-#2} #6 ; #8}}
    
\newcommand{\moixa}[2]{\infer0{\Sigma;\refu{\Delta},#1:\refu{#2}\vdash #1:\refu{#2}}}

\newcommand{\refudiffintro}[4]{\hypo{\pro{\Sigma};\refu{\Delta},#1:\refu{#2}\vdash #3:\refu{#4}}
      \infer1{\pro{\Sigma};\refu{\Delta}\vdash \refu{#4 - #2} : #3.#1\lambda }}


\newcommand{\holerefudiffintro}[6]{\hypo{\pro{\Sigma};\refu{\Delta},#1:\refu{#2}\vdash #3:#5\refu{#4}#6}
      \infer1{\pro{\Sigma};\refu{\Delta}\vdash #5\refu{#4 - #2}#6 : #3.#1\lambda }}

    
\newcommand{\refuimplintro}[4]{\hypo{\pro{\Sigma};\refu{\Delta}\vdash #1: \pro{#2}}
      \hypo{\pro{\Sigma};\refu{\Delta}\vdash #3:\refu{#4}}
      \infer2{\pro{\Sigma};\refu{\Delta}\vdash #1\circ#3:\refu{\sigma \rightarrow \delta}}}


\newcommand{\holerefuimplintro}[8]{\hypo{\pro{\Sigma};\refu{\Delta}\vdash #1: #5\pro{#2}#6}
      \hypo{\pro{\Sigma};\refu{\Delta}\vdash #3:#7\refu{#4}#8}
      \infer2{\pro{\Sigma};\refu{\Delta}\vdash #1\circ#3:#5;#7\refu{\sigma \rightarrow \delta}#6;#8}}

    
\newcommand{\refuintro}[4]{\hypo{\pro{\Sigma},#1:\pro{#2};\refu{\Delta}\vdash #3:\contr{#4}}
      \infer1{\pro{\Sigma};\refu{\Delta}\vdash \tilde{\mu}#1:\pro{#2}.#3:\refu{#2}}}

\newcommand{\holerefuintro}[6]{\hypo{\pro{\Sigma},#1:\pro{#2};\refu{\Delta}\vdash #3:#5\contr{#4}#6}
      \infer1{\pro{\Sigma};\refu{\Delta}\vdash #5\refu{#2}#6:#3.\pro{#2}:\mu}}


    
\newcommand{\prointro}[4]{ \hypo{\pro{\Sigma};\refu{\Delta},#1:\refu{#2}\vdash #3:\contr{#4}}
      \infer1{\pro{\Sigma};\refu{\Delta}\vdash \mu #1:\refu{#2}.#3:\pro{#2}}}

\newcommand{\holeprointro}[6]{ \hypo{\pro{\Sigma};\refu{\Delta},#1:\refu{#2}\vdash #3:#5\contr{#4}#6}
      \infer1{\pro{\Sigma};\refu{\Delta}\vdash \mu #1:\refu{#2}.#3:#5\pro{#2}#6}}

\newcommand{\holecut}[7]{ \hypo{\pro{\Sigma};\refu{\Delta}\vdash #1:#4\pro{#3}#5}
      \hypo{\pro{\Sigma};\refu{\Delta}\vdash #6\refu{#3}#7:#2}
      \infer2{\pro{\Sigma};\refu{\Delta}\vdash \langle #1: #4;#6\contr{#3}#5;#7:#2\rangle}}

\newcommand{\cut}[3]{ \hypo{\pro{\Sigma};\refu{\Delta}\vdash #1:\pro{#3}}
      \hypo{\pro{\Sigma};\refu{\Delta}\vdash \refu{#3}:#2}
      \infer2{\pro{\Sigma};\refu{\Delta}\vdash \langle #1:\contr{#3}:#2\rangle}}

\newcommand{\symcut}[3]{ \hypo{\pro{\Sigma}\vdash #1:\pro{#3}\dashv \refu{\Delta}}
      \hypo{\pro{\Sigma}\vdash \refu{#3}:#2 \dashv \refu{\Delta}}
      \infer2{\pro{\Sigma}\vdash \rangle #1:\contr{#3}:#2\langle \dashv \refu{\Delta}}}


