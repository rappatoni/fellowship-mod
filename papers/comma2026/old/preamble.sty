% Substitution rules



\newcommand{\envsubpremone}{
  \hypo{V;\pro{\Sigma}\vdash t[\refu{\sigma}:\alpha] \dashv \refu{\Delta};E}
 }


\newcommand{\envsubpremtwo}{
      \hypo{V';\pro{\Sigma}\vdash \refu{\sigma}:E \dashv \refu{\Delta};E'}
    }

% prem1, prem2, metatermcontext, termcontext, term, substerm, subsvar, envcontext, metaenvcontext
\NewDocumentCommand{\envsub}{O{\envsubpremone} O{\envsubpremtwo} O{V''} O{\pro{\Sigma}} O{t} O{E} O{\alpha} O{\refu{\Delta}} O{E''}}{
  \begin{prooftree}
      #1
      #2
      \infer2{#3;#4\vdash #5[#6/#7] \dashv #8;#9}
    \end{prooftree}}

\newcommand{\termsubpremone}{
  \hypo{V;\pro{\Sigma}\vdash [X:\pro{\sigma}]t \dashv \refu{\Delta};E}
 }


\newcommand{\termsubpremtwo}{
      \hypo{V';\pro{\Sigma}'\vdash v:\pro{\sigma} \dashv \refu{\Delta}';E'}
    }
  
% prem1, prem2, metatermcontext, termcontext, substerm, subsvar,term, envcontext, metaenvcontext
\NewDocumentCommand{\termsub}{O{\termsubpremone} O{\termsubpremtwo} O{V''} O{\pro{\Sigma}} O{E} O{\alpha}  O{t} O{\refu{\Delta}} O{E''}}{
  \begin{prooftree}
      #1
      #2
      \infer2{#3;#4\vdash [#5/#6]#7 \dashv #8;#9}
    \end{prooftree}}
\newcommand{\peirce}{\mu *: \refu{((\sigma\rightarrow \delta) \rightarrow \sigma) \rightarrow \sigma}.\rangle\lambda f:\pro{(\sigma\rightarrow \delta) \rightarrow \sigma}.\mu \alpha:\refu{\sigma}.\rangle f :\contr{(\sigma\rightarrow \delta) \rightarrow \sigma}: \lambda x:\sigma.\mu\refu{\sigma}.\rangle x:\contr{\sigma}:\alpha\langle \circ \alpha \langle :: *\langle}

\newcommand{\peirceshort}{\mu *: \refu{((\sigma\rightarrow \delta) \rightarrow \sigma) \rightarrow \sigma}.\rangle\lambda f.\mu \alpha:\refu{\sigma}.\rangle f :\contr{(\sigma\rightarrow \delta) \rightarrow \sigma}: \lambda x:\sigma.\mu\refu{\sigma}.\rangle x:\contr{\sigma}:\alpha\langle \circ \alpha \langle :: *\langle}      
      
